# Server Configuration
PORT=5000

# OpenAI API Key (Required for AI features)
# Get your key here: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Gemini API Key (Alternative for AI features)
# Get your key here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Firebase Configuration
# Path to your Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./chatbotai-firebase-adminsdk.json
